// ─── FUNCIONES LEDS SENSOR ────────────────────────────
void apagarLEDs(){
  digitalWrite(LED_ROJO,    LOW);
  digitalWrite(LED_AMARILLO,LOW);
  digitalWrite(LED_VERDE,   LOW);
}

void controlarLEDs(int valor){
  apagarLEDs();
  if     (valor < 1000)                      digitalWrite(LED_ROJO,    HIGH);
  else if(valor >= 1000 && valor < 2500)     digitalWrite(LED_AMARILLO,HIGH);
  else                                       digitalWrite(LED_VERDE,   HIGH);
}

// ─── ENVÍO SENSOR A SUPABASE ──────────────────────────
void enviarSupabase(int valor){
  HTTPClient http;
  String url = String(SUPABASE_URL) + "/rest/v1/sensores";
  http.begin(url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  String body = "{\"valor_ldr\":" + String(valor) + "}";
  int code = http.POST(body);
  Serial.printf("Supabase sensor → %d | LDR: %d\n", code, valor);
  http.end();
}

// ─── CONSULTAR ESTADO LED INTEGRADO ───────────────────
// Lee la tabla led_control (id=1) y aplica el estado al pin GPIO 2
void consultarLedControl(){
  HTTPClient http;
  String url = String(SUPABASE_URL) + "/rest/v1/led_control?id=eq.1&select=estado";
  http.begin(url);
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);

  int code = http.GET();
  if(code == 200){
    String payload = http.getString();
    // Respuesta esperada: [{"estado":true}] o [{"estado":false}]
    StaticJsonDocument<128> doc;
    DeserializationError err = deserializeJson(doc, payload);
    if(!err && doc.is<JsonArray>() && doc.as<JsonArray>().size() > 0){
      bool nuevo = doc[0]["estado"].as<bool>();
      if(nuevo != estadoLedBuiltin){
        estadoLedBuiltin = nuevo;
        digitalWrite(LED_BUILTIN, estadoLedBuiltin ? HIGH : LOW);
        Serial.printf("LED integrado (GPIO2): %s\n", estadoLedBuiltin ? "ENCENDIDO" : "APAGADO");
      }
    }
  } else {
    Serial.printf("Error consultando led_control: HTTP %d\n", code);
  }
  http.end();
}

// ─── SERVIDOR WEB (MODO AP) ────────────────────────────
void iniciarServidorAP(){
  server.on("/", HTTP_GET, [](){
    server.send(200, "text/html", HTML_CONFIG);
  });

  server.on("/scan", HTTP_GET, [](){
    int n = WiFi.scanNetworks();
    String json = "{\"networks\":[";
    for(int i = 0; i < n; i++){
      if(i > 0) json += ",";
      json += "{\"ssid\":\"" + WiFi.SSID(i) + "\","
              "\"rssi\":"    + WiFi.RSSI(i) + "}";
    }
    json += "]}";
    server.send(200, "application/json", json);
  });

  server.on("/save", HTTP_POST, [](){
    String body = server.arg("plain");
    StaticJsonDocument<256> doc;
    deserializeJson(doc, body);
    String ssid = doc["ssid"].as<String>();
    String pass = doc["pass"].as<String>();

    prefs.begin("wifi-cfg", false);
    prefs.putString("ssid", ssid);
    prefs.putString("pass", pass);
    prefs.end();

    server.send(200,"application/json",
      "{\"msg\":\"Guardado. Reiniciando en 3s...\"}");
    delay(3000);
    ESP.restart();
  });

  server.begin();
  Serial.println("Servidor AP iniciado en http://192.168.4.1");
}

// ─── MODO AP ──────────────────────────────────────────
void iniciarModoAP(){
  modoAP = true;
  apagarLEDs();
  digitalWrite(LED_AMARILLO, HIGH);  // Indica modo config

  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, AP_PASS);
  Serial.printf("AP: %s → 192.168.4.1\n", AP_SSID);
  iniciarServidorAP();
}

// ─── CONECTAR WIFI ────────────────────────────────────
bool conectarWiFi(const String& ssid, const String& pass){
  Serial.printf("Conectando a %s...\n", ssid.c_str());
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid.c_str(), pass.c_str());

  int intentos = 0;
  while(WiFi.status() != WL_CONNECTED && intentos < 30){
    delay(500);
    Serial.print(".");
    intentos++;
  }
  if(WiFi.status() == WL_CONNECTED){
    Serial.printf("\nConectado. IP: %s\n", WiFi.localIP().toString().c_str());
    return true;
  }
  return false;
}

// ─── SETUP ────────────────────────────────────────────
void setup(){
  Serial.begin(115200);

  pinMode(LED_ROJO,    OUTPUT);
  pinMode(LED_AMARILLO,OUTPUT);
  pinMode(LED_VERDE,   OUTPUT);
  pinMode(LED_BUILTIN, OUTPUT);   // LED integrado GPIO 2
  pinMode(BTN_CONFIG,  INPUT_PULLUP);

  apagarLEDs();
  digitalWrite(LED_BUILTIN, LOW);  // LED integrado apagado al inicio

  // Leer credenciales guardadas
  prefs.begin("wifi-cfg", true);
  savedSSID = prefs.getString("ssid", "");
  savedPASS = prefs.getString("pass", "");
  prefs.end();

  // Forzar modo AP si botón presionado o no hay credenciales
  bool botonPresionado = (digitalRead(BTN_CONFIG) == LOW);

  if(savedSSID.isEmpty() || botonPresionado){
    Serial.println("→ Modo configuración AP");
    iniciarModoAP();
  } else {
    bool ok = conectarWiFi(savedSSID, savedPASS);
    if(!ok){
      Serial.println("WiFi falló → Modo AP");
      iniciarModoAP();
    }
  }
}

// ─── LOOP ─────────────────────────────────────────────
void loop(){
  if(modoAP){
    server.handleClient();
    return;
  }

  // Reconexión automática
  if(WiFi.status() != WL_CONNECTED){
    Serial.println("WiFi perdido, reconectando...");
    conectarWiFi(savedSSID, savedPASS);
    delay(1000);
    return;
  }

  unsigned long ahora = millis();

  // ── Leer LDR y enviar a Supabase ──
  int ldr = analogRead(PIN_LDR);
  controlarLEDs(ldr);
  Serial.printf("LDR: %d\n", ldr);

  if(ahora - ultimoEnvio >= INTERVALO_SENSOR){
    if(abs(ldr - ultimoValorEnviado) > 5){   // solo si cambia suficiente
      enviarSupabase(ldr);
      ultimoValorEnviado = ldr;
    }
    ultimoEnvio = ahora;
  }

  // ── Consultar estado LED integrado cada 3s ──
  if(ahora - ultimaConsultaLed >= INTERVALO_LED){
    consultarLedControl();
    ultimaConsultaLed = ahora;
  }

  delay(10);
}